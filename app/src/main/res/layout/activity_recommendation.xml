<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F2F1">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Security Recommendations"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#004D40"
            android:layout_marginBottom="20dp"/>

        <!-- Box 1 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardElevation="6dp"
            card_view:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:padding="18dp"
                android:text="Disable location when not required to reduce tracking risk."
                android:textSize="16sp"
                android:textColor="#333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </androidx.cardview.widget.CardView>

        <!-- Box 2 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardElevation="6dp"
            card_view:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:padding="18dp"
                android:text="Remove microphone permission from apps that do not require it."
                android:textSize="16sp"
                android:textColor="#333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </androidx.cardview.widget.CardView>

        <!-- Box 3 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardElevation="6dp"
            card_view:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:padding="18dp"
                android:text="Review camera permissions to avoid unauthorized recording."
                android:textSize="16sp"
                android:textColor="#333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </androidx.cardview.widget.CardView>

        <!-- Box 4 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardElevation="6dp"
            card_view:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:padding="18dp"
                android:text="Uninstall unused apps to reduce your digital footprint."
                android:textSize="16sp"
                android:textColor="#333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </androidx.cardview.widget.CardView>

        <!-- Box 5 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            card_view:cardElevation="6dp"
            card_view:cardCornerRadius="12dp">

            <TextView
                android:padding="18dp"
                android:text="Disable Bluetooth scanning when not required for better privacy."
                android:textSize="16sp"
                android:textColor="#333"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>